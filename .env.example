# ========================================
# TRADEMATE TRADING BOT CONFIGURATION
# ========================================

# Deriv API Configuration
DERIV_API_TOKEN=your_deriv_api_token_here
DERIV_APP_ID=1089

# Account Settings
DEMO_MODE=true
INITIAL_STAKE=10.0

# Trading Parameters
TRADING_SYMBOL=R_100
CANDLE_INTERVAL=300
MIN_CONFIRMATIONS=3

# Risk Management
RISK_PER_TRADE=0.02
MAX_DAILY_LOSS=0.05
MAX_CONSECUTIVE_LOSSES=3
MAX_TRADES_PER_DAY=10
MIN_RISK_REWARD_RATIO=1.5

# Strategy Parameters
EMA_FAST=50
EMA_SLOW=200
RSI_PERIOD=14
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70

# Optional: Telegram Notifications
# TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# TELEGRAM_CHAT_ID=your_chat_id

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/trademate.log

# Environment
ENVIRONMENT=development
