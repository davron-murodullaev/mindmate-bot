# ── Bot Configuration ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
ADMIN_USER_IDS=123456789
BOT_USERNAME=your_bot_username   # without @, e.g.: mindmate_bot

# ── Telegram Mini App (Web Dashboard) ──────────────────────────────
# 1. Deploy to Render as a "web" service
# 2. Copy your Render URL (e.g. https://mindmate-bot.onrender.com)
# 3. Paste it below and redeploy — the "📱 Open Dashboard" button appears
WEBAPP_URL=
ENABLE_WEBAPP=true
API_PORT=8080

# ── AI Provider Selection ──────────────────────────────────────────
# "openai" yoki "anthropic" - bittasini tanlang. Bitta env-var bilan
# OpenAI'dan Claude'ga (yoki teskari) o'tasiz, kod o'zgarmaydi.
AI_PROVIDER=openai

# OpenAI (ChatGPT) — AI_PROVIDER=openai bo'lganda ishlatiladi
OPENAI_API_KEY=sk-your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (Claude) — AI_PROVIDER=anthropic bo'lganda ishlatiladi
ANTHROPIC_API_KEY=sk-ant-your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5

# Umumiy AI sozlamalari
MAX_TOKENS=2048
TEMPERATURE=0.7

# ── Database Configuration ─────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/mindmate
DB_POOL_MIN_SIZE=5
DB_POOL_MAX_SIZE=20

# ── Application Settings ───────────────────────────────────────────
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=false

# ── Feature Flags ──────────────────────────────────────────────────
ENABLE_REMINDERS=true
ENABLE_ANALYTICS=true

# ── Reminder Settings ──────────────────────────────────────────────
REMINDER_CHECK_INTERVAL=60

# ── Timezone ───────────────────────────────────────────────────────
TIMEZONE=Asia/Tashkent
